# ── GitHub OAuth App credentials ──────────────────────────────────────────────
# Register your OAuth App at https://github.com/settings/applications/new
# See README.md for full setup instructions.

VITE_GITHUB_CLIENT_ID=your_client_id_here

# Deployed URL of auth-worker.js on Puter (no trailing slash).
# Deploy with:  puter worker deploy auth-worker.js
# Then set GH_CLIENT_ID and GH_CLIENT_SECRET in the Puter worker dashboard.
VITE_AUTH_WORKER_URL=https://your-worker.puter.site

# The callback URL you set in the OAuth App settings.
# For GitHub Pages: https://space-gen.github.io/solarhub/
# For local dev:    http://localhost:5173/
VITE_GITHUB_REDIRECT_URI=http://localhost:5173/
